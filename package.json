{
  "name": "chat-app-frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "dotenv -c .env -- nodemon",
    "build": "npm run build:server && npm run build:frontend",
    "build:frontend": "next build",
    "build:server": "tsc --project tsconfig.build.json",
    "start": "NODE_ENV=production node dist/server/index.js",
    "lint": "next lint",
    "precommit": "npm run prettify && lint-staged --no-stash",
    "prettify": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss}\""
  },
  "dependencies": {
    "@easyflow-chat/easyflow-web-components": "0.0.12-alpha",
    "@types/node": "20.13.0",
    "autoprefixer": "10.4.19",
    "axios": "1.7.2",
    "cookie-parser": "1.4.6",
    "cookies-next": "4.2.1",
    "dotenv-cli": "7.4.2",
    "express": "4.19.2",
    "formik": "2.4.6",
    "next": "14.2.3",
    "next-connect": "1.0.0",
    "next-i18next": "15.3.0",
    "react": "18",
    "react-dom": "18",
    "socket.io-client": "^4.7.5",
    "tailwindcss": "3.4.3",
    "yup": "1.4.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.7",
    "@types/express": "4.17.21",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.11.0",
    "eslint": "8.56.0",
    "eslint-config-next": "14.2.3",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "husky": "9.0.11",
    "lint-staged": "15.2.5",
    "nodemon": "3.1.2",
    "postcss": "8.4.38",
    "postcss-flexbugs-fixes": "5.0.2",
    "postcss-preset-env": "9.5.14",
    "prettier": "3.3.0",
    "prettier-plugin-sort-json": "4.0.0",
    "prettier-plugin-tailwindcss": "0.6.1",
    "typescript": "5.4.5"
  },
  "browser": {
    "child_process": false
  }
}
