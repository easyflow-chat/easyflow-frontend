  },
  "devDependencies": {
    "@types/node": "20",
    "@types/react": "18",
    "@types/react-dom": "18",
    "autoprefixer": "10.0.1",
    "eslint": "8",
    "eslint-config-next": "14.1.4",
    "postcss": "8",
    "tailwindcss": "3.4.3",
    "typescript": "5"
  }
